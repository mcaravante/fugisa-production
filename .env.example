# =============================================================================
# Variables de entorno para FUGISA Web
# =============================================================================
# Copiar este archivo como .env.local y completar los valores:
#   cp .env.example .env.local
# =============================================================================

# -----------------------------------------------------------------------------
# Configuracion del sitio (publicas - visibles en el navegador)
# -----------------------------------------------------------------------------

# URL completa del sitio (incluir https://)
NEXT_PUBLIC_SITE_URL=https://www.fugisa.com.ar

# Dominio de produccion (sin protocolo)
NEXT_PUBLIC_PRODUCTION_DOMAIN=www.fugisa.com.ar

# Permitir indexacion por buscadores (true / false)
NEXT_PUBLIC_ALLOW_INDEXING=true

# -----------------------------------------------------------------------------
# Configuracion SMTP (para el formulario de contacto)
# -----------------------------------------------------------------------------

# Host del servidor SMTP (ej: smtp.gmail.com, mail.fugisa.com.ar)
SMTP_HOST=

# Puerto SMTP (587 para STARTTLS, 465 para SSL)
SMTP_PORT=587

# Usar conexion segura SSL/TLS (true para puerto 465, false para 587)
SMTP_SECURE=false

# Usuario SMTP (generalmente el email completo)
SMTP_USER=

# Contrasena SMTP
SMTP_PASSWORD=

# Direccion de email que aparece como remitente (opcional, por defecto usa SMTP_USER)
SMTP_FROM=

# Email de destino donde llegan los mensajes del formulario de contacto
CONTACT_EMAIL=info@fugisa.com.ar
